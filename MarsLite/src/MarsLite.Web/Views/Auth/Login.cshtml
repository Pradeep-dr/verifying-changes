@inherits Nancy.ViewEngines.Razor.NancyRazorViewBase<MarsLite.Web.Modules.LoginViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — DrDoctor</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/Content/css/site.css" />
</head>
<body class="auth-body">
    <main class="auth-card-wrap">
        <div class="auth-card">
            <div class="auth-brand">DrDoctor</div>
            <h1 class="auth-title">Sign in to your account</h1>
            <p class="auth-sub">Staff portal &mdash; please enter your credentials.</p>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger py-2" role="alert">@Model.Error</div>
            }

            <form method="post" action="/auth/login" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                <div class="dd-field mb-3">
                    <label for="username">Email</label>
                    <input id="username" name="Username" type="email" required autofocus />
                </div>
                <div class="dd-field mb-3">
                    <label for="password">Password</label>
                    <input id="password" name="Password" type="password" required />
                </div>
                <button type="submit" class="dd-btn-primary w-100" style="justify-content:center; padding:.6rem 1rem;">Sign in</button>
            </form>

            <div class="auth-hint mt-4">
                <strong>Demo creds:</strong> <code>staff@drdoctor.dev</code> / <code>password123</code>
            </div>
        </div>
    </main>
</body>
</html>
