<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mars Lite</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<header>
    <nav class="navbar navbar-expand-sm dd-nav">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-hospital" style="color: var(--dd-teal);"></i>
                Mars<span class="brand-dot"> Lite</span>
                <span class="dd-nav-env">POC</span>
            </a>
            <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2 me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WaitingLists" ? "active" : "")"
                           href="/waitinglists/1">
                            <i class="bi bi-list-ul me-1"></i>Waiting Lists
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "active" : "")"
                           href="/appointments">
                            <i class="bi bi-calendar-check me-1"></i>Appointments
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <span style="color:#475569; font-size:.8rem;"><i class="bi bi-person-circle me-1"></i>Staff</span>
                </div>
            </div>
        </div>
    </nav>
</header>

@RenderBody()

<footer class="dd-footer">
    <div class="d-flex justify-content-between align-items-center">
        <span>&copy; 2026 DrDoctor &mdash; Mars Lite POC</span>
        <span>Playwright test target &middot; .NET 9 &middot; ASP.NET Core MVC</span>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
