@{
    ViewData["Title"] = "Waiting Lists — Patient Lists";
    var pid = (int)ViewBag.ProviderId;
}

<!-- Page header -->
<div class="dd-page-hdr">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/waitinglists/@pid">Waiting Lists</a></li>
            <li class="breadcrumb-item active">Patient Lists</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center justify-content-between">
        <h1 class="page-title">Waiting Lists</h1>
        <span class="page-meta"><i class="bi bi-building me-1"></i>Provider @pid</span>
    </div>
    <ul class="nav dd-tabs">
        <li class="nav-item"><a class="nav-link" href="/waitinglists/@pid">Overview</a></li>
        <li class="nav-item"><a class="nav-link" href="/waitinglists/@pid/config">Configuration</a></li>
        <li class="nav-item"><a class="nav-link" href="/waitinglists/@pid/entries">Entries</a></li>
        <li class="nav-item"><a class="nav-link active" href="/waitinglists/@pid/patientlists">Patient Lists</a></li>
    </ul>
</div>

<!-- Content -->
<div class="dd-body">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <p class="text-muted mb-0" style="font-size:.875rem;">Grouped patient lists assigned to this provider.</p>
        <button class="btn-dd-primary btn btn-sm"><i class="bi bi-plus me-1"></i>Create list</button>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <div class="dd-card">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <div class="fw-semibold mb-1">General Surgery Group A</div>
                        <span class="dd-tag dd-tag-blue">Active</span>
                    </div>
                    <i class="bi bi-people-fill text-primary fs-5"></i>
                </div>
                <dl class="dd-dl mb-3">
                    <dt>Patients</dt><dd>12</dd>
                    <dt>Specialty</dt><dd>General Surgery</dd>
                    <dt>Created</dt><dd>08 Jan 2026</dd>
                </dl>
                <a href="/waitinglists/@pid/entries" class="btn-dd-ghost btn btn-sm w-100">View entries</a>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="dd-card">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <div class="fw-semibold mb-1">Orthopaedics Group B</div>
                        <span class="dd-tag dd-tag-teal">Active</span>
                    </div>
                    <i class="bi bi-people-fill fs-5" style="color:var(--dd-teal);"></i>
                </div>
                <dl class="dd-dl mb-3">
                    <dt>Patients</dt><dd>7</dd>
                    <dt>Specialty</dt><dd>Orthopaedics</dd>
                    <dt>Created</dt><dd>15 Jan 2026</dd>
                </dl>
                <a href="/waitinglists/@pid/entries" class="btn-dd-ghost btn btn-sm w-100">View entries</a>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="dd-card">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <div class="fw-semibold mb-1">Cardiology Priority List</div>
                        <span class="pill pill-waiting">Paused</span>
                    </div>
                    <i class="bi bi-people-fill text-warning fs-5"></i>
                </div>
                <dl class="dd-dl mb-3">
                    <dt>Patients</dt><dd>5</dd>
                    <dt>Specialty</dt><dd>Cardiology</dd>
                    <dt>Created</dt><dd>22 Jan 2026</dd>
                </dl>
                <a href="/waitinglists/@pid/entries" class="btn-dd-ghost btn btn-sm w-100">View entries</a>
            </div>
        </div>
    </div>
</div>
