@{
    ViewData["Title"] = "Waiting Lists";
    var pid = (int)ViewBag.ProviderId;
}

<!-- Page header -->
<div class="dd-page-hdr">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
            <li class="breadcrumb-item active">Waiting Lists</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center justify-content-between">
        <h1 class="page-title">Waiting Lists</h1>
        <span class="page-meta"><i class="bi bi-building me-1"></i>Provider @pid</span>
    </div>
    <ul class="nav dd-tabs">
        <li class="nav-item"><a class="nav-link active" href="/waitinglists/@pid">Overview</a></li>
        <li class="nav-item"><a class="nav-link" href="/waitinglists/@pid/config">Configuration</a></li>
        <li class="nav-item"><a class="nav-link" href="/waitinglists/@pid/entries">Entries</a></li>
        <li class="nav-item"><a class="nav-link" href="/waitinglists/@pid/patientlists">Patient Lists</a></li>
    </ul>
</div>

<!-- Content -->
<div class="dd-body">

    <!-- Stats -->
    <div class="dd-stat-bar d-flex mb-4">
        <div class="dd-stat flex-fill">
            <div class="dd-stat-val text-primary">3</div>
            <div class="dd-stat-lbl">Active Lists</div>
        </div>
        <div class="dd-stat flex-fill">
            <div class="dd-stat-val" style="color:var(--dd-warning);">24</div>
            <div class="dd-stat-lbl">Total Entries</div>
        </div>
        <div class="dd-stat flex-fill">
            <div class="dd-stat-val text-success">8</div>
            <div class="dd-stat-lbl">Assigned Today</div>
        </div>
        <div class="dd-stat flex-fill">
            <div class="dd-stat-val" style="color:var(--dd-danger);">2</div>
            <div class="dd-stat-lbl">Overdue</div>
        </div>
    </div>

    <!-- Waiting lists table -->
    <div class="dd-card p-0">
        <div class="dd-card-hdr px-4 pt-4">
            <h2 class="dd-card-title"><i class="bi bi-list-ul me-2 text-primary"></i>Active Waiting Lists</h2>
            <button class="btn-dd-primary btn"><i class="bi bi-plus me-1"></i>New List</button>
        </div>
        <table class="dd-table">
            <thead>
                <tr>
                    <th>List Name</th>
                    <th>Specialty</th>
                    <th>Entries</th>
                    <th>Avg Wait</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-medium">General Surgery WL</td>
                    <td>General Surgery</td>
                    <td>12</td>
                    <td>18 days</td>
                    <td><span class="pill pill-confirmed">Active</span></td>
                    <td><a href="/waitinglists/@pid/entries" class="btn-dd-ghost btn btn-sm">View entries</a></td>
                </tr>
                <tr>
                    <td class="fw-medium">Orthopaedics WL</td>
                    <td>Orthopaedics</td>
                    <td>7</td>
                    <td>32 days</td>
                    <td><span class="pill pill-confirmed">Active</span></td>
                    <td><a href="/waitinglists/@pid/entries" class="btn-dd-ghost btn btn-sm">View entries</a></td>
                </tr>
                <tr>
                    <td class="fw-medium">Cardiology WL</td>
                    <td>Cardiology</td>
                    <td>5</td>
                    <td>45 days</td>
                    <td><span class="pill pill-waiting">Paused</span></td>
                    <td><a href="/waitinglists/@pid/entries" class="btn-dd-ghost btn btn-sm">View entries</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
