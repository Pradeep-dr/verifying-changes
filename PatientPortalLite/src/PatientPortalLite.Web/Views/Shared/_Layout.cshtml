@{
    string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool isAppointments = controller == "Appointments";
    bool isLetters      = controller == "Letters";
    bool isHome         = controller == "Home";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Patient Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="pp-app">

<header>
    <nav class="pp-nav" aria-label="Primary">
        <div class="pp-nav-inner">
            <ul class="pp-nav-links">
                <li><a asp-controller="Appointments" asp-action="Index" class="@(isAppointments || isHome ? "active" : "")">Appointments</a></li>
                <li><a asp-controller="Letters"      asp-action="Index" class="@(isLetters ? "active" : "")">Letters</a></li>
                <li><a href="#" onclick="return false;">Messages</a></li>
                <li><a href="#" onclick="return false;">Forms</a></li>
                <li><a href="#" onclick="return false;">Test results</a></li>
                <li><a href="#" onclick="return false;">My health</a></li>
                <li><a href="#" onclick="return false;">Trackers</a></li>
                <li><a href="#" onclick="return false;">Resources</a></li>
            </ul>
            <div class="pp-nav-right">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="#" onclick="return false;">Settings</a>
                    <form method="post" action="/auth/logout" class="m-0 d-flex">
                        @Html.AntiForgeryToken()
                        <button type="submit">Sign out</button>
                    </form>
                }
            </div>
        </div>
    </nav>
</header>

<main class="pp-main">
    <div class="pp-container">
        @RenderBody()
    </div>
</main>

<footer class="pp-footer">
    <div>
        <a href="#" onclick="return false;">Accessibility &amp; Language Options</a>
        <a href="#" onclick="return false;">Visit our help section</a>
    </div>
    <div class="brand mt-2">Service provided by <strong>DrDoctor</strong></div>
</footer>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
