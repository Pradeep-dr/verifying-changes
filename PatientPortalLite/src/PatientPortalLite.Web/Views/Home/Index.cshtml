@model PatientPortalLite.Web.Models.HomeVm
@{
    ViewData["Title"] = "Appointments";
}

<div class="pp-banner pp-banner-notice" role="status">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <div><strong>Please review and update your contact details</strong> <i class="bi bi-chevron-right" style="font-size:.85rem;"></i></div>
</div>

<div class="pp-banner pp-banner-info" role="status">
    <i class="bi bi-calendar3" style="color:var(--pp-primary-dark);"></i>
    <div>
        <div class="pp-banner-title">Book your appointment: General Surgery</div>
        You can choose your own appointment date and time. <a href="/appointments">Start booking now</a>
    </div>
</div>

@if (Model.UpcomingAppointments.Count == 0)
{
    <div class="pp-card">
        <p class="text-muted mb-0">You have no upcoming appointments.</p>
    </div>
}
else
{
    foreach (var appt in Model.UpcomingAppointments)
    {
        var apptLabel = appt.ScheduledAt.ToString("ddd dd MMM yyyy - h:mmtt").Replace("AM", "am").Replace("PM", "pm");
        <a class="pp-appt-card" href="/appointments/@appt.Id">
            <div class="pp-appt-date">@apptLabel</div>
            <div class="pp-appt-service">@appt.Specialty Service</div>
            <div class="pp-appt-location">@appt.Location</div>
        </a>
    }
}
