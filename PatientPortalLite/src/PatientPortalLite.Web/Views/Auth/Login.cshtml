@model PatientPortalLite.Web.Models.LoginVm
@{
    ViewData["Title"] = "Sign in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — Patient Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="pp-auth-body">
    <main class="pp-auth-card-wrap">
        <div class="pp-auth-card">
            <div class="pp-auth-brand">Patient Portal</div>
            <h1 class="pp-auth-title">Confirm your identity</h1>
            <p class="pp-auth-sub">Step 1 of 2 — please enter your details exactly as they appear on your hospital records.</p>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger py-2" role="alert">@Model.Error</div>
            }

            <form method="post" action="/auth/login" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="pp-field">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" autocomplete="family-name" autofocus required />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>

                <div class="pp-field">
                    <label asp-for="DateOfBirth"></label>
                    <input asp-for="DateOfBirth" type="date" required />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>

                <div class="pp-field">
                    <label asp-for="Postcode"></label>
                    <input asp-for="Postcode" autocomplete="postal-code" required />
                    <span asp-validation-for="Postcode" class="text-danger small"></span>
                </div>

                <button type="submit" class="pp-btn-primary">Continue</button>
            </form>

            <div class="pp-auth-hint mt-4">
                <strong>Demo patient:</strong>
                <ul>
                    <li>Last name: <code>Johnson</code></li>
                    <li>DOB: <code>1985-04-12</code></li>
                    <li>Postcode: <code>SW1A 1AA</code></li>
                </ul>
            </div>
        </div>
    </main>
</body>
</html>
