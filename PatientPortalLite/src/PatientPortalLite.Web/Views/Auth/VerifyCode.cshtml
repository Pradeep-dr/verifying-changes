@model PatientPortalLite.Web.Models.VerifyCodeVm
@{
    ViewData["Title"] = "Verify code";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verify code — Patient Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="pp-auth-body">
    <main class="pp-auth-card-wrap">
        <div class="pp-auth-card">
            <div class="pp-auth-brand">Patient Portal</div>
            <h1 class="pp-auth-title">Enter verification code</h1>
            <p class="pp-auth-sub">Step 2 of 2 — we've sent a 6-digit code to your registered mobile.</p>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger py-2" role="alert">@Model.Error</div>
            }

            <form method="post" action="/auth/verify" novalidate>
                @Html.AntiForgeryToken()

                <div class="pp-field">
                    <label asp-for="Code">6-digit code</label>
                    <input asp-for="Code" class="pp-otc-input" inputmode="numeric"
                           maxlength="6" pattern="\d{6}" autocomplete="one-time-code" autofocus required />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <button type="submit" class="pp-btn-primary">Verify and continue</button>
            </form>

            <div class="pp-auth-hint mt-4">
                <strong>Demo code:</strong> <code>123456</code>
            </div>
        </div>
    </main>
</body>
</html>
