{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Bash(npm install)",
			"Bash(npm install:*)",
			"Bash(npm test)",
			"Bash(npm run *)",
			"Bash(npx playwright *)",
			"Bash(dotnet build *)",
			"Bash(dotnet run *)",
			"Bash(dotnet test *)",
			"Bash(dotnet restore *)",
			"Bash(git status:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git show:*)",
			"Bash(git blame:*)",
			"Bash(git branch)",
			"Bash(git branch -a)",
			"Bash(git branch -r)",
			"Bash(git branch -v)",
			"Bash(git config core.hooksPath:*)",
			"Bash(git config --get core.hooksPath)",
			"WebFetch(domain:playwright.dev)",
			"WebFetch(domain:docs.anthropic.com)",
			"WebFetch(domain:learn.microsoft.com)",
			"WebFetch(domain:github.com)"
		],
		"deny": [
			"Bash(git commit *)",
			"Bash(git push *)",
			"Bash(git reset --hard:*)",
			"Bash(git checkout -- *)",
			"Bash(git clean -f:*)"
		]
	},
	"env": {
		"CLAUDE_CODE_ENABLE_TELEMETRY": "0",
		"DOTNET_CLI_TELEMETRY_OPTOUT": "1"
	}
}
