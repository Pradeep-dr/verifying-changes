{
  "name": "drdoctor-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "report": "playwright show-report",
    "test:marslite": "playwright test --config playwright.marslite.config.ts",
    "test:marslite:ui": "playwright test --config playwright.marslite.config.ts --ui",
    "auth:marslite": "playwright test --config playwright.marslite.config.ts --project=setup",
    "test:pp": "playwright test --config playwright.patientportal.config.ts",
    "test:pp:ui": "playwright test --config playwright.patientportal.config.ts --ui",
    "auth:pp": "playwright test --config playwright.patientportal.config.ts --project=setup"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@axe-core/playwright": "latest",
    "@types/node": "latest",
    "dotenv": "latest",
    "typescript": "latest"
  }
}
